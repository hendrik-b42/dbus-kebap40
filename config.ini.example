# =============================================================================
# KEBA P40 Venus OS Treiber - Konfiguration
# =============================================================================
# Anpassen und als config.ini speichern.

[General]
# Log-Level: DEBUG, INFO, WARNING, ERROR
log_level = INFO

# DRY-RUN MODUS (empfohlen fuer den ersten Test!)
# Bei true: liest alle Keba-Daten und berechnet den Sollstrom,
# schreibt aber NICHTS zur Wallbox. So kannst du im Log sehen,
# was der Treiber tun WUERDE, ohne dass etwas passiert.
# Auf false setzen, wenn alles passt.
dry_run = true

[Keba]
# IP-Adresse der Keba P40 Wallbox (MUSS angepasst werden!)
host = 192.168.1.100

# Modbus TCP Port (Standard: 502, lt. Handbuch S.8)
port = 502

# Verbindungs-Timeout in Sekunden
timeout = 5.0

[Venus]
# Eindeutige Device-Instance fuer Venus OS D-Bus
# Muss einzigartig unter allen evcharger-Diensten sein
device_instance = 40

# Lademodus (/Mode), wird beim Umstellen in der GUI automatisch hier
# gespeichert und ueberlebt so einen Neustart:
#   0 = Manuell (Strom per Hand, laedt 3-phasig)
#   1 = Automatisch (PV-Ueberschuss)
#   2 = Geplant
mode = 1

# Position der Wallbox in der Anlage (/Position). MUSS zur tatsaechlichen
# Verkabelung passen, sonst zaehlt Venus die Ladeleistung doppelt (faellt
# v.a. bei 1-phasigem Laden auf):
#   0 = AC-Eingang / Netzseite (netzparallel, keine Critical-Loads-Ausgang)
#   1 = AC-Ausgang / hinter dem Wechselrichter (Critical Loads)
# Faustregel: ist /Ac/ConsumptionOnOutput im System leer -> 0.
position = 0

[Charging]
# --- PV-Ueberschussladung ---

# Minimaler Ladestrom in mA (lt. Handbuch Register 5004: 6000-32000)
# Unter diesem Wert wird die Ladung pausiert (Register 5004 = 0)
min_current_ma = 6000

# Puffer in Watt: Wieviel Leistung soll NICHT ins Auto gehen,
# um Netzbezug zu vermeiden (z.B. fuer Hausverbrauch-Schwankungen)
surplus_buffer_w = 200

# Schrittweite fuer sanftes Hoch-/Runterregeln in mA
ramp_step_ma = 1000

# Update-Intervall in Sekunden (min. 0.5s lt. Handbuch fuer Lesen)
update_interval_s = 2.0

# --- Phasenumschaltung ---
# HINWEIS: Register 5050/5052 benoetigen ggf. ein Firmware-Update!
# (lt. Handbuch Section 4.5/4.6: "Function will be made available
#  with a later software update")
phase_switching = true

# --- EMS Failsafe (Handbuch Section 4.7, S.22-23) ---
# Verhalten bei Verbindungsverlust zum Raspberry Pi:

# Failsafe-Strom in mA (0 = Ladung stoppen, 6000-32000 = weiter laden)
failsafe_current_ma = 0

# Failsafe-Timeout in Sekunden (0 = deaktiviert, 5-600)
# Nach dieser Zeit ohne Modbus-Kommando greift der Failsafe-Strom
failsafe_timeout_s = 30

[Battery]
# ==========================================================================
# Batterie-Prioritaet: Wer bekommt den PV-Ueberschuss zuerst?
# ==========================================================================
#
# Venus OS ESS regelt normalerweise selbst, wieviel PV-Strom in die
# Batterie geht. Der Grid-Meter-Wert (/Ac/Grid/Power) zeigt nur, was
# NACH der Batterie-Ladung uebrig ist. Dieser Treiber kann zusaetzlich
# die Batterie-Ladeleistung "umleiten", indem er sie als verfuegbaren
# Ueberschuss fuer das Auto betrachtet.
#
# Drei Strategien stehen zur Verfuegung:
#
# "grid_only" (konservativ):
#   Nur was wirklich ins Netz eingespeist wird, geht ins Auto.
#   Die Batterie wird vom ESS-System ganz normal geladen.
#   -> Batterie hat IMMER Vorrang.
#   -> Gut wenn die Batterie klein ist und du sie fuer den Abend brauchst.
#
# "battery_above_soc" (empfohlen):
#   Unter dem SOC-Schwellwert (soc_threshold) hat die Batterie Vorrang.
#   Ueber dem Schwellwert wird die Batterie-Ladeleistung auch fuer
#   das Auto freigegeben.
#   -> Batterie bis z.B. 80% laden, dann Auto.
#   -> Bester Kompromiss: Batterie hat genug Reserve fuer den Abend,
#      und das Auto bekommt trotzdem genuegend PV-Strom.
#
# "ev_first" (aggressiv):
#   Die Batterie-Ladeleistung wird immer als verfuegbar betrachtet.
#   -> Auto hat IMMER Vorrang vor der Batterie.
#   -> Sinnvoll wenn das Auto viel Strom braucht und die Batterie
#      weniger wichtig ist.
#
strategy = battery_above_soc

# Ab welchem Batterie-SOC (%) darf der Ueberschuss ans Auto gehen?
# Nur relevant bei Strategie "battery_above_soc".
# Beispiel: 80 = Batterie wird zuerst auf 80% geladen, danach geht
# der PV-Ueberschuss (inkl. Batterie-Ladeleistung) ins Auto.
soc_threshold = 80

# Unter diesem SOC (%) wird die EV-Ladung IMMER pausiert,
# egal welche Strategie aktiv ist (Batterie-Schutz).
# Relevant wenn die Batterie sich abends entlaedt und das Auto
# noch haengt - dann soll die Batterie nicht leer gesaugt werden.
min_soc = 20

[ChargeMode]
# ==========================================================================
# Dicker Schalter: Normal-Laden vs. PV-Ueberschuss-Laden
# ==========================================================================
#
# Live umschaltbar via D-Bus-Pfad /ChargeMode (Venus GUI / MQTT).
# Der hier eingetragene Wert ist der STARTWERT nach Treiber-Neustart;
# bei jeder Aenderung ueber D-Bus wird er hier automatisch persistiert.
#
# 0 = Normal-Laden (immer 3-phasig, normal_current_ma, PV egal)
# 1 = PV-Ueberschuss-Laden (smart, mit Batterie-Verlaengerung ab battery_extend_soc)
default = 1

# Normal-Modus Ladestrom in mA pro Phase (3-phasig fest).
# 16000 mA * 3 Phasen * 230 V ~= 11 kW
normal_current_ma = 16000

# Ab welchem Hausakku-SOC darf im PV-Modus zusaetzlich 1-phasig
# 6A (~1,4 kW) aus dem Akku ins Auto gezogen werden, auch wenn
# der reine PV-Ueberschuss nicht reicht?
battery_extend_soc = 80

# Hysterese fuer den Batterie-Extend (vermeidet Flattern).
# Aktivieren bei SOC >= battery_extend_soc,
# deaktivieren erst wieder bei SOC < (battery_extend_soc - extend_hysteresis_soc).
extend_hysteresis_soc = 3

# Mindestdauer (Sekunden), die ein Modus / eine Phasenanzahl stehen
# muss, bevor wieder umgeschaltet werden darf. Verhindert Flapping.
mode_min_hold_s = 60

# Tageszeit-Reserve fuer den Hausakku - er soll bis Sonnenaufgang reichen.
# Format: HH:MM-HH:MM=PROZENT, mit Komma getrennt.
# Bereiche duerfen ueber Mitternacht gehen (z.B. 22:00-02:00).
# Solange der Akku unter dieser Reserve ist, wird er NICHT ins Auto entladen
# (battery_above_soc-Strategie wird ignoriert, kein Batterie-Extend).
# Default-Kurve fuer mittelgrosse Hausbatterie (10-20 kWh):
reserve_schedule = 06:00-17:00=20, 17:00-22:00=30, 22:00-02:00=40, 02:00-06:00=50

# Fallback-Reserve (%), falls reserve_schedule eine Luecke hat
# oder ein Eintrag nicht parsebar ist.
reserve_fallback = 40
